# Mystica Tagging Bridge — environment.
# Copy to `.env` and fill. NOTHING in this file is committed (.gitignore excludes .env).
# Values below are the Phase-0-CONFIRMED settings (2026-07-13) — see FINDINGS.md.

# ---- Safety switch -------------------------------------------------------
# DRY_RUN=true (the default) NEVER writes to OmniSend — it only computes and
# prints the diff. Set DRY_RUN=false to enable live writes (and even then the
# CLI requires the explicit --live flag as a second gate).
DRY_RUN=true

# ---- Render (app DB — source of truth + identity + interaction) ----------
# Prefer a READ-ONLY role. The client also forces read-only transactions.
RENDER_DATABASE_URL=postgresql://USER:PASSWORD@HOST.oregon-postgres.render.com/DBNAME?sslmode=require

# CONFIRMED schema. The users table is "user" (singular; a reserved word — quoted
# by the client). onboarding_completed_at is unused, so created_at anchors install+signup.
RENDER_USERS_TABLE=user
RENDER_USER_ID_COL=id
RENDER_EMAIL_COL=email
RENDER_INSTALLED_AT_COL=created_at
RENDER_SIGNED_UP_AT_COL=created_at
RENDER_LAST_SEEN_COL=last_seen_at
RENDER_NAME_COL=name

# Subscription status for contacts CREATED by --create-missing (subscribed | nonSubscribed).
CREATE_MISSING_STATUS=subscribed
# Scope to real customers only (exclude psychic advisors + admins + soft-deleted).
RENDER_ROSTER_WHERE=user_role = 'user' AND deleted_at IS NULL
# Recency cutoff: only tag app users seen within this many days (pure recency,
# applied to roster + interaction scope). 180 = 6 months (~6,803 users). 0 = full base.
RENDER_ACTIVE_WITHIN_DAYS=180

# ---- Interaction source --------------------------------------------------
# render (default) = chats + daily draws from Render, joined user_id->email in-DB
# with no loss. posthog = the optional supplement. Leave as render.
INTERACTION_SOURCE=render
# Render interaction schema (confirmed). Override only if the schema changes.
RENDER_CHAT_TABLE=chat_message
RENDER_CHAT_USER_COL=user_id
RENDER_CHAT_SESSION_COL=chat_session_id
RENDER_CHAT_TIME_COL=created_at
RENDER_DRAW_TABLE=daily_card_draw
RENDER_DRAW_USER_COL=user_id
RENDER_DRAW_TIME_COL=drawn_at
RENDER_READING_TABLE=reading
RENDER_READING_USER_COL=user_id
RENDER_READING_TIME_COL=created_at
# Soulmate reading fulfillment stages (app: reading_abandoned / reading_delivered).
RENDER_READING_INTENT_TABLE=soulmate_reading_intent
READING_ABANDONED_STATUS=pending_inputs
RENDER_READING_DELIVERED_COL=delivered_at

# Only assert posthog_distinct_id once it's confirmed to equal the Render uuid.
# Until then the app:* tags carry adoption; keep this false.
WRITE_DISTINCT_ID_ON_INSTALL=false

# ---- Leading-indicator MILESTONE tags ------------------------------------
# Count thresholds encoded as cumulative tags (OmniSend can't segment on numeric
# props). A user with >=N of an activity gets `<base>_<N>` for each milestone N.
# chats -> app: chat_1/_2/_3 ; draws -> app: daily_draw_1/_2 ; interactions -> app: interaction_11
APP_CHAT_MILESTONES=1,2,3
APP_DRAW_MILESTONES=1,2
APP_INTERACTION_MILESTONES=11

# ---- OmniSend (the tag/segment destination) — REQUIRED to run ------------
OMNISEND_API_KEY=

# ---- PostHog (OPTIONAL — not needed with INTERACTION_SOURCE=render) -------
POSTHOG_API_KEY=
POSTHOG_PROJECT=67576
POSTHOG_HOST=https://us.posthog.com

# ---- Slack alerting (optional but recommended) ---------------------------
SLACK_BOT_TOKEN=
SLACK_CHANNEL_BRIDGE=#mystica-bridge

# ---- Guardrail -----------------------------------------------------------
# Abort (unless --force) if a single run would change more than this fraction
# of the addressable audience. The initial backfill WILL exceed this — use --force.
MAX_DIFF_FRACTION=0.30
